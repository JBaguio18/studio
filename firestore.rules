/**
 * Core Philosophy:
 * This ruleset enforces a security model based on strict ownership, role-based
 * access control (RBAC), and structural segregation for public vs. private data.
 * It prioritizes Authorization Independence, meaning that authorization decisions
 * are made using denormalized data directly on the documents being secured,
 * avoiding slow and costly cross-document lookups in rules.
 *
 * Data Structure:
 * The structure separates private, user-specific data into subcollections under
 * /users/{userId} (e.g., my_content, notifications). Publicly readable data
 * like published content and creator profiles are stored in top-level collections
 * (/published_content, /creator_profiles) to enable efficient, secure querying.
 *
 * Key Security Decisions:
 * - Structural Segregation: Content is split into two collections: a public,
 *   read-only `/published_content` for discovery, and a private
 *   `/users/{userId}/my_content` subcollection for user-specific drafts and
 *   management. This makes list queries secure and performant.
 * - Denormalization for Authorization: Profile collections use the user's
 *   authentication UID as the document ID for direct access. Content documents
 *   contain a denormalized `ownerUserId` to link back to the owner without
 *   requiring a `get()` call.
 * - Data Validation: In addition to authorization, rules validate incoming
 *   data to enforce application logic, such as preventing users from forging
 *   timestamps or bypassing the content moderation queue.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------//
    // Helper Functions
    //-------------------------------------------------------------------------//

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    // Validates that key IDs match the authenticated user on creation.
    function isNewOwner(userId) {
      return isOwner(userId) && incomingData().id == userId;
    }

    // Validates timestamps and immutability of key fields on update.
    function isConsistentOnUpdate(userId) {
      return isOwner(userId)
             && incomingData().id == existingData().id
             && incomingData().createdAt == existingData().createdAt
             && incomingData().updatedAt == request.time;
    }
    
    function isSelfOwnedProfileUpdate() {
        return isOwner(existingData().userId)
            && incomingData().userId == existingData().userId
            && incomingData().isVerified == existingData().isVerified // Users can't verify themselves
            && incomingData().updatedAt == request.time;
    }


    //-------------------------------------------------------------------------//
    // Collection Rules
    //-------------------------------------------------------------------------//

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent user enumeration
      allow create: if isNewOwner(userId) && incomingData().createdAt == request.time;
      allow update: if isConsistentOnUpdate(userId);
      allow delete: if isOwner(userId);
    }

    match /creator_profiles/{creatorProfileId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(creatorProfileId) && incomingData().userId == creatorProfileId && incomingData().createdAt == request.time;
      allow update: if isSelfOwnedProfileUpdate();
      allow delete: if isOwner(existingData().userId);
    }

    match /business_profiles/{businessProfileId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessProfileId) && incomingData().userId == businessProfileId && incomingData().createdAt == request.time;
      allow update: if isSelfOwnedProfileUpdate();
      allow delete: if isOwner(existingData().userId);
    }

    match /fan_profiles/{fanProfileId} {
      allow get: if isOwner(fanProfileId);
      allow list: if false;
      allow create: if isOwner(fanProfileId) && incomingData().userId == fanProfileId && incomingData().createdAt == request.time;
      allow update: if isOwner(existingData().userId) && incomingData().updatedAt == request.time;
      allow delete: if isOwner(existingData().userId);
    }

    match /published_content/{contentId} {
      // This collection is a public, read-only mirror managed by a backend process.
      allow get, list: if true;
      allow write: if false;
    }

    match /users/{userId}/my_content/{contentId} {
      allow get, list, delete: if isOwner(userId);
      
      // On create, user must be owner, set timestamps correctly, and cannot set status to 'published'
      allow create: if isOwner(userId)
                    && incomingData().ownerUserId == userId
                    && incomingData().createdAt == request.time
                    && !(incomingData().status in ['published', 'rejected']);

      // On update, user must be owner, timestamps must be correct, and certain transitions are disallowed.
      allow update: if isOwner(userId)
                    && incomingData().ownerUserId == existingData().ownerUserId
                    && incomingData().createdAt == existingData().createdAt
                    && incomingData().updatedAt == request.time
                    // Prevent users from publishing or rejecting their own content.
                    && !(incomingData().status in ['published', 'rejected'])
                    // Prevent editing content that is already live (a copy exists in /published_content)
                    && existingData().status != 'published';
    }

    match /tags/{tagId} {
      // Tags are public, read-only data managed by a backend process.
      allow get, list: if true;
      allow write: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow get, list, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) && incomingData().userId == userId;
    }
  }
}
